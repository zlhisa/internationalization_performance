@article{frankCapitalStructureDecisions2009,
  title = {Capital {{Structure Decisions}}: {{Which Factors Are Reliably Important}}?},
  shorttitle = {Capital {{Structure Decisions}}},
  author = {Frank, Murray Z. and Goyal, Vidhan K.},
  year = 2009,
  journal = {Financial Management},
  volume = {38},
  number = {1},
  eprint = {20486683},
  eprinttype = {jstor},
  pages = {1--37},
  publisher = {[Financial Management Association International, Wiley]},
  issn = {0046-3892},
  urldate = {2026-06-27},
  abstract = {This paper examines the relative importance of many factors in the capital structure decisions of publicly traded American firms from 1950 to 2003. The most reliable factors for explaining market leverage are: median industry leverage (+ effect on leverage), market-to-book assets ratio (-), tangibility (+), profits (-), log of assets (+), and expected inflation (+). In addition, we find that dividend-paying firms tend to have lower leverage. When considering book leverage, somewhat similar effects are found. However, for book leverage, the impact of firm size, the market-to-book ratio, and the effect of inflation are not reliable. The empirical evidence seems reasonably consistent with some versions of the trade-off theory of capital structure.},
  file = {/Users/lisa/Zotero/storage/IIWZ43KC/Frank and Goyal - 2009 - Capital Structure Decisions Which Factors Are Reliably Important.pdf}
}

@article{gonzalezLeverageCorporatePerformance2013,
  title = {Leverage and Corporate Performance: {{International}} Evidence},
  shorttitle = {Leverage and Corporate Performance},
  author = {Gonz{\'a}lez, V{\'i}ctor M.},
  year = 2013,
  month = jan,
  journal = {International Review of Economics \& Finance},
  volume = {25},
  pages = {169--184},
  issn = {1059-0560},
  doi = {10.1016/j.iref.2012.07.005},
  urldate = {2026-06-27},
  abstract = {This paper analyzes the effect of financial leverage on corporate operating performance and how this effect varies across countries. Results for 10,375 firms in 39 countries indicate that the performance of firms with greater leverage is significantly reduced compared to their competitors in industry downturns, in line with the importance of financial distress costs. However, this effect varies according to the legal origin of the countries, being positive in French civil law countries. The protection of shareholder rights and the strength of legal enforcement are the main variables explaining the effect of financial leverage on performance.},
  keywords = {Investor protection,Legal enforcement,Legal origin,Leverage,Operating performance},
  file = {/Users/lisa/Zotero/storage/EA8Y9M8Q/González - 2013 - Leverage and corporate performance International evidence.pdf;/Users/lisa/Zotero/storage/J7JMTCRF/S1059056012000652.html}
